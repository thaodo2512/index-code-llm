{
  "name": "codegraph-workspace",
  "version": "0.1.0",
  "description": "Turn many code repositories into one searchable workspace for MCP clients, on top of CodeGraph.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "codegraph-workspace": "dist/cli.js"
  },
  "files": [
    "dist",
    "workspace.example.json",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "serve": "node dist/cli.js serve --stdio",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "better-sqlite3": "^11.8.0",
    "commander": "^13.0.0",
    "execa": "^9.5.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
